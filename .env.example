# ── App
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:3001

# ── Database
DATABASE_URL=postgresql://presente:presente_dev_pass@localhost:5432/presente_dev
DATABASE_URL_TEST=postgresql://presente:presente_dev_pass@localhost:5432/presente_test

# ── Redis
REDIS_URL=redis://localhost:6379

# ── JWT
JWT_SECRET=sua-chave-secreta-muito-longa-aqui-minimo-32-caracteres
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ── AWS S3 (usar MinIO em dev)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=presente_minio
AWS_SECRET_ACCESS_KEY=presente_minio_secret
AWS_S3_BUCKET=presente-local
AWS_S3_ENDPOINT=http://localhost:9000
AWS_CLOUDFRONT_DOMAIN=

# ── Firebase FCM
FIREBASE_PROJECT_ID=presente-app
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@presente-app.iam.gserviceaccount.com

# ── Zenvia SMS (usar mock em dev)
ZENVIA_API_KEY=sua-api-key-zenvia
ZENVIA_SENDER=Presente

# ── AWS SES
SES_REGION=sa-east-1
SES_FROM_EMAIL=noreply@presente.com.br
