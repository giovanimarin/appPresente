{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@presente/shared": ["../../packages/shared/src"],
      "@presente/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "ts-node": {
    "require": ["tsconfig-paths/register"],
    "transpileOnly": true
  },
  "include": ["src", "prisma"],
  "exclude": ["node_modules", "dist"]
}
