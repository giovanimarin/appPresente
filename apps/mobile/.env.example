# Copie para .env e ajuste conforme o ambiente
# O Expo carrega variáveis prefixadas com EXPO_PUBLIC_ automaticamente

# API de staging (padrão no código quando não definido)
EXPO_PUBLIC_API_URL=https://staging-api.apppresente.com.br/api/v1

# API local (quando a API está rodando na máquina)
# EXPO_PUBLIC_API_URL=http://SEU_IP_LOCAL:3001/api/v1
