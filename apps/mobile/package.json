{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "start:staging": "EXPO_PUBLIC_API_URL=https://staging-api.apppresente.com.br/api/v1 expo start",
    "start:local": "EXPO_PUBLIC_API_URL=http://localhost:3001/api/v1 expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "build:local:dev": "eas build --profile development --platform android --local",
    "build:local:staging": "eas build --profile preview --platform android --local",
    "build:local:prod": "eas build --profile production --platform android --local"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@tanstack/react-query": "^5.100.9",
    "axios": "^1.16.0",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-linking": "~8.0.12",
    "expo-notifications": "^55.0.23",
    "expo-router": "~6.0.23",
    "expo-status-bar": "~3.0.9",
    "lucide-react-native": "^1.14.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-css-interop": "^0.2.3",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.15.4",
    "react-native-worklets": "^0.8.3",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "babel-preset-expo": "^54.0.10",
    "nativewind": "^4.2.3",
    "typescript": "~5.9.2"
  },
  "private": true
}
